# SQLite configuration (recommended for development)
USE_SQLITE=true
SQLITE_PATH=./data/civicvote.db

# Optional: PostgreSQL connection URL (for compatibility)
# Leave empty to use SQLite
# For local Postgres:
# DATABASE_URL=postgres://postgres:password@localhost:5432/civicvote
# For Supabase:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
# DATABASE_URL=

# Set to true for hosted databases like Supabase
DATABASE_SSL=false

# Server port override
PORT=4000
